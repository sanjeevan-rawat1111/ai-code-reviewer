# Copy to .env and fill in your key:
#   cp .env.example .env

# ── FREE option: Google Gemini via AI Studio ──────────────────────────────────
# Get a free key in 2 minutes (no credit card):
#   1. Go to https://aistudio.google.com/apikey
#   2. Sign in with Google
#   3. Click "Create API key" → copy it here
REVIEWER_LLM__API_KEY=paste-your-google-ai-studio-key-here

# Model + endpoint are already defaulted in settings.py to Gemini Flash.
# Nothing else is required to run locally.

# ── Override model / endpoint (optional) ─────────────────────────────────────
# Groq (free, fast): sign up at https://console.groq.com
# REVIEWER_LLM__MODEL=llama-3.1-70b-versatile
# REVIEWER_LLM__API_KEY=gsk_your_groq_key
# REVIEWER_LLM__BASE_URL=https://api.groq.com/openai/v1

# OpenAI (paid):
# REVIEWER_LLM__MODEL=gpt-4o
# REVIEWER_LLM__API_KEY=sk-...
# REVIEWER_LLM__BASE_URL=https://api.openai.com/v1

# Ollama (local, no key):
# REVIEWER_LLM__MODEL=codellama
# REVIEWER_LLM__API_KEY=ollama
# REVIEWER_LLM__BASE_URL=http://localhost:11434/v1

# ── GitHub (only needed for: cr review github) ────────────────────────────────
# Get at: https://github.com/settings/tokens (free, needs repo:read scope)
# REVIEWER_GITHUB__TOKEN=ghp_...

# ── GitLab (only needed for: cr review gitlab) ────────────────────────────────
# REVIEWER_GITLAB__TOKEN=glpat-...
